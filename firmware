void runCalibrationProcedure() { 
  tft.setTextSize(1); tft.fillScreen(TFT_BLACK); tft.setTextColor(TFT_WHITE, TFT_BLACK); tft.setTextSize(2); 
  tft.setCursor(20, 100); tft.print("CLICK TOP-LEFT"); delay(500); tft.fillCircle(10, 10, 5, TFT_RED); 
  while (!ts.touched()) delay(10); TS_Point p1 = ts.getPoint(); while (ts.touched()) delay(10); 
  ts_x1 = p1.x; ts_y1 = p1.y; 
  tft.fillScreen(TFT_BLACK); tft.setCursor(20, 100); tft.print("CLICK BOT-RIGHT"); delay(500); tft.fillCircle(310, 230, 5, TFT_RED); 
  while (!ts.touched()) delay(10); TS_Point p2 = ts.getPoint(); while (ts.touched()) delay(10); 
  ts_x2 = p2.x; ts_y2 = p2.y; 
  saveCalibration(); tft.fillScreen(TFT_GREEN); delay(500); 
}

bool isTouched(int &x, int &y) {
  if (ts.touched()) { 
    TS_Point p = ts.getPoint(); 
    if (ts_x1 == ts_x2) ts_x2 = ts_x1 + 1; 
    if (ts_y1 == ts_y2) ts_y2 = ts_y1 + 1;
    x = map(p.x, ts_x1, ts_x2, 0, 320); y = map(p.y, ts_y1, ts_y2, 0, 240); 
    if (x < 0) x = 0; if (x > 320) x = 320; if (y < 0) y = 0; if (y > 240) y = 240; 
    return true; 
  } 
  return false;
}

