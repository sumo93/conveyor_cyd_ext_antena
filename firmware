void forceRefreshMQTT(int index) {
  if (WiFi.status() == WL_CONNECTED && printers[index].configValid) {
    char pub_topic[100]; sprintf(pub_topic, "device/%s/request", printers[index].serial.c_str()); 
    if (mqtt.connected()) { mqtt.publish(pub_topic, "{\"pushing\":{\"sequence_id\":\"1\",\"command\":\"pushall\"},\"user_id\":\"1\"}"); Serial.println("Force Refresh Sent!"); }
  }
}

int findIntInPayload(byte* payload, unsigned int length, const char* key) {
  int keyLen = strlen(key);
  for (unsigned int i = 0; i < length - keyLen; i++) {
    bool match = true;
    for (int k = 0; k < keyLen; k++) {
      if ((char)payload[i+k] != key[k]) { match = false; break; }
    }
    if (match) {
      int valStart = i + keyLen;
      while(valStart < length && ((char)payload[valStart] == ' ' || (char)payload[valStart] == ':')) valStart++;
      String numStr = "";
      while(valStart < length && isDigit((char)payload[valStart])) {
        numStr += (char)payload[valStart]; valStart++;
      }
      if (numStr.length() > 0) return numStr.toInt();
    }
  }
  return -1; 
}

void mqttGlobalCallback(char* topic, byte* payload, unsigned int length) {
  String t = String(topic); int foundIndex = -1;
  for(int i=0; i<4; i++) { if (printers[i].configValid && t.indexOf(printers[i].serial) >= 0) { foundIndex = i; break; } }
  if (foundIndex == -1) return; 
  
  printers[foundIndex].msg_count++;

  int raw_stage = findIntInPayload(payload, length, "\"stg_cur\"");
  int raw_sub_stage = findIntInPayload(payload, length, "\"mc_print_sub_stage\"");
  int raw_progress = findIntInPayload(payload, length, "\"mc_percent\"");
  
  if (raw_progress != -1) printers[foundIndex].progress = raw_progress;
  if (raw_sub_stage != -1) printers[foundIndex].sub_status = raw_sub_stage;

  if (raw_stage != -1) {
    printers[foundIndex].status = raw_stage;
    
    if (raw_stage == 4 || raw_stage == 14 || (raw_sub_stage == 4 && raw_stage != -1)) { 
       printers[foundIndex].statusText = "POOP!"; printers[foundIndex].color = palette[idx_col_act];
       
       if (conveyorState == STATE_IDLE) { 
          unsigned long now = millis();
          if (now - printers[foundIndex].lastTriggerTime > 90000) {
             printers[foundIndex].poopCounter++;
             printers[foundIndex].lastTriggerTime = now; 
             
             preferences.begin("cyd-v60", false);
             preferences.putInt(("pc"+String(foundIndex)).c_str(), printers[foundIndex].poopCounter);
             preferences.end();

             if (printers[foundIndex].poopCounter >= printers[foundIndex].poopTarget) {
                 activePrinterIndex = foundIndex; 
                 targetTimeM1_ms = printers[foundIndex].runTimeSec * 1000; 
                 detectionTime = millis(); 
                 conveyorState = STATE_WAITING_TO_START; 
                 printers[foundIndex].poopCounter = 0; 
                 
                 preferences.begin("cyd-v60", false);
                 preferences.putInt(("pc"+String(foundIndex)).c_str(), 0);
                 preferences.end();
             }
          }
       }
    } else {
       if (raw_stage >= 6 && raw_stage <= 30) { printers[foundIndex].statusText = "PRINTING"; printers[foundIndex].color = palette[idx_col_ok]; } 
       else { printers[foundIndex].statusText = "READY"; printers[foundIndex].color = palette[idx_col_ok]; }
    }
    return;
  }
}

void networkLoop(void * parameter) {
  netClient.setInsecure(); 
  mqtt.setBufferSize(40000); 
  mqtt.setCallback(mqttGlobalCallback); 
  unsigned long lastPushTime = 0;
  
  unsigned long connectionStart = 0;
  const unsigned long ROTATION_INTERVAL = 5000; 

  for(;;) { 
    if (wifi_ssid.length() > 2) { if (WiFi.status() != WL_CONNECTED) { WiFi.begin(wifi_ssid.c_str(), wifi_pass.c_str()); unsigned long startW = millis(); while (WiFi.status() != WL_CONNECTED && millis() - startW < 5000) vTaskDelay(100); } }
    
    if (WiFi.status() == WL_CONNECTED) {
      Printer &p = printers[currentMqttIndex];
      
      if (!p.configValid) { 
         p.statusText = "SETUP"; p.color = UI_CARD_BG; 
         currentMqttIndex++; if (currentMqttIndex >= 4) currentMqttIndex = 0; 
         vTaskDelay(50); continue; 
      }

      mqtt.setServer(p.ip.c_str(), 8883);
      if (!mqtt.connected()) {
        if (mqtt.connect("CYD_Scanner", "bblp", p.accessCode.c_str())) {
           p.mqttStatus = "OK"; 
           connectionStart = millis(); 
           char topic[100]; sprintf(topic, "device/%s/report", p.serial.c_str()); mqtt.subscribe(topic);
           char pub_topic[100]; sprintf(pub_topic, "device/%s/request", p.serial.c_str()); mqtt.publish(pub_topic, "{\"pushing\":{\"sequence_id\":\"1\",\"command\":\"pushall\"},\"user_id\":\"1\"}");
        } else {
           p.mqttStatus = "ERR"; p.statusText = "OFFLINE"; p.color = palette[idx_col_err]; p.status = -1;
           currentMqttIndex++; if (currentMqttIndex >= 4) currentMqttIndex = 0; 
           vTaskDelay(1000); continue; 
        }
      }

      while(mqtt.connected()) {
         mqtt.loop(); 
         
         if (millis() - lastPushTime > 5000) {
            char pub_topic[100]; sprintf(pub_topic, "device/%s/request", p.serial.c_str()); 
            mqtt.publish(pub_topic, "{\"pushing\":{\"sequence_id\":\"1\",\"command\":\"pushall\"},\"user_id\":\"1\"}");
            lastPushTime = millis();
         }
         
         if (millis() - connectionStart > ROTATION_INTERVAL) {
             mqtt.disconnect(); 
             currentMqttIndex++; if (currentMqttIndex >= 4) currentMqttIndex = 0;
             break; 
         }

         vTaskDelay(5); 
      }
    } else { vTaskDelay(1000); }
  }
}

