void updatePrinterBox(int index) {
  if (currentScreen != SCREEN_MAIN) return;
  Printer &p = printers[index];
  
  int currentConveyorState = (activePrinterIndex == index) ? conveyorState : -1;
  
  if (p.statusText == p.last_statusText && 
      p.mqttStatus == p.last_mqttStatus && 
      p.color == p.last_color && 
      p.name == p.last_name && 
      p.progress == p.last_progress &&
      p.last_conveyor_state_id == currentConveyorState &&
      p.last_poop_counter == p.poopCounter) { 
        return; 
  }

  p.last_statusText = p.statusText; 
  p.last_mqttStatus = p.mqttStatus; 
  p.last_color = p.color; 
  p.last_name = p.name; 
  p.last_progress = p.progress;
  p.last_conveyor_state_id = currentConveyorState;
  p.last_poop_counter = p.poopCounter;

  tft.setTextSize(1); 
  int w = 150; int h = 95; int x = (index % 2) * 160 + 5; int y = (index < 2) ? 40 : 140;
  
  tft.fillRoundRect(x, y, w, h, 8, UI_CARD_BG); tft.fillRoundRect(x+5, y+10, 6, h-20, 3, p.color);
  tft.setTextDatum(TL_DATUM); tft.setTextColor(UI_TEXT_SUB, UI_CARD_BG); tft.drawString(p.name, x + 18, y + 10, 2); tft.drawString(p.ip, x + 18, y + 28, 1);   
  tft.setTextColor(p.color, UI_CARD_BG); int font = (p.statusText.length() > 7) ? 2 : 4; tft.drawString(p.statusText, x + 18, y + 55, font);

  if (p.mqttStatus == "OK" && p.statusText != "OFFLINE") {
    drawProgressRing(x + w - 25, y + 25, 18, p.progress, p.color);
  }

  tft.setTextDatum(BL_DATUM);
  tft.setTextColor(TFT_YELLOW, UI_CARD_BG);
  tft.drawString("Bin: " + String(p.poopCounter) + "/" + String(p.poopTarget), x + 18, y + h - 5, 2);

