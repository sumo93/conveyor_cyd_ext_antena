void openKeyboard(String &var, String title) { keyboardTargetVariable = &var; keyboardTargetInt = nullptr; keyboardBuffer = var; keyboardTitle = title; keyboardMode = 0; currentScreen = SCREEN_KEYBOARD; drawKeyboard(true); }
void openNumKeyboard(int &var, String title) { keyboardTargetInt = &var; keyboardTargetVariable = nullptr; keyboardBuffer = String(var); keyboardTitle = title; keyboardMode = 2; currentScreen = SCREEN_KEYBOARD; drawKeyboard(true); }

void handleKeyboardInput(int x, int y) { 
  if(y < 40) { 
    if(x < 60) {
      if (keyboardTitle.indexOf("WiFi") >= 0) { currentScreen = SCREEN_SETUP_NETWORK; drawSetupNetwork(); } 
      else if (keyboardTitle.indexOf("Sleep") >= 0) { currentScreen = SCREEN_SETUP_DISPLAY; drawSetupDisplay(); } 
      else if (keyboardTitle.indexOf("Delay") >= 0 || keyboardTitle.indexOf("Run") >= 0 || keyboardTitle.indexOf("Limit") >= 0 || keyboardTitle.indexOf("Lmt") >= 0) { currentScreen = SCREEN_SETUP_MOTORS; drawSetupMotors(); } 
      else { currentScreen = SCREEN_PRINTER_SETTINGS; drawPrinterSettings(editingPrinterIndex); } 
      return;
    }
    if(x > 260) {
      if (keyboardTargetVariable != nullptr) *keyboardTargetVariable = keyboardBuffer; 
      if (keyboardTargetInt != nullptr) *keyboardTargetInt = keyboardBuffer.toInt(); 
      savePreferences(); 
      if (keyboardTitle.indexOf("WiFi") >= 0) { currentScreen = SCREEN_SETUP_NETWORK; drawSetupNetwork(); } 
      else if (keyboardTitle.indexOf("Sleep") >= 0) { currentScreen = SCREEN_SETUP_DISPLAY; drawSetupDisplay(); } 
      else if (keyboardTitle.indexOf("Delay") >= 0 || keyboardTitle.indexOf("Run") >= 0 || keyboardTitle.indexOf("Limit") >= 0 || keyboardTitle.indexOf("Lmt") >= 0) { currentScreen = SCREEN_SETUP_MOTORS; drawSetupMotors(); } 
      else { currentScreen = SCREEN_PRINTER_SETTINGS; drawPrinterSettings(editingPrinterIndex); } 
      return;
    }
  }

  int startY = 85; int w = 28; int h = 28; int gapX = 4; int gapY = 4;
  if (y >= startY && y <= startY + 4*(h+gapY)) {
    int r = (y - startY) / (h + gapY);
    int c = (x - 2) / (w + gapX);
    if (r >= 0 && r < 4 && c >= 0 && c < 10) {
      const char* (*currentKeys)[10];
      if(keyboardMode == 0) currentKeys = keysLower;
      else if(keyboardMode == 1) currentKeys = keysUpper;
      else currentKeys = keysSym;
      keyboardBuffer += currentKeys[r][c];
      drawKeyboard(false);
      return;
    }
  }

  int yRow5 = startY + 4*(h+gapY) + 5;
  if (y >= yRow5 && y <= yRow5 + 32) {
    if (x >= 2 && x <= 42) { keyboardMode = (keyboardMode == 1) ? 0 : 1; drawKeyboard(true); }
    else if (x >= 46 && x <= 86) { keyboardMode = (keyboardMode == 2) ? 0 : 2; drawKeyboard(true); }
    else if (x >= 90 && x <= 230) { keyboardBuffer += " "; drawKeyboard(false); }
    else if (x >= 234 && x <= 318) {
      if (keyboardBuffer.length() > 0) { keyboardBuffer.remove(keyboardBuffer.length() - 1); drawKeyboard(false); }
    }
  }
}

// =================================================================================
// === 8. HANDLE TOUCH / OVLÁDÁNÍ DOTYKEM ===
// =================================================================================

void handleTouch(int x, int y) {
  last_interaction = millis();

  if (currentScreen == SCREEN_KEYBOARD) {
    handleKeyboardInput(x, y);
    return;
  }

  if (currentScreen == SCREEN_MAIN) {
    if (y < 35) {
      if (x >= 160 && x < 235) { runCalibrationProcedure(); drawMainScreen(); }
      else if (x >= 240) { currentScreen = SCREEN_MENU_HUB; drawMenuHub(); }
      return;
    }
    for (int i = 0; i < 4; i++) {
      int bx = (i % 2) * 160 + 5;
      int by = (i < 2) ? 40 : 140;
      if (x >= bx && x <= bx + 150 && y >= by && y <= by + 95) {
        editingPrinterIndex = i;
        currentScreen = SCREEN_PRINTER_SETTINGS;
        drawPrinterSettings(editingPrinterIndex);
        return;
      }
    }
  } 
  else if (currentScreen == SCREEN_MENU_HUB) {
    if (y < 40 && x > 240) { currentScreen = SCREEN_MAIN; drawMainScreen(); return; }
    if (x >= 15 && x <= 155 && y >= 40 && y <= 110) { currentScreen = SCREEN_SETUP_NETWORK; drawSetupNetwork(); }
    else if (x >= 170 && x <= 310 && y >= 40 && y <= 110) { currentScreen = SCREEN_SETUP_MOTORS; drawSetupMotors(); }
    else if (x >= 15 && x <= 155 && y >= 125 && y <= 195) { currentScreen = SCREEN_SETUP_COLORS; drawSetupColors(); }
    else if (x >= 170 && x <= 310 && y >= 125 && y <= 195) { currentScreen = SCREEN_SETUP_DISPLAY; drawSetupDisplay(); }
  }
  else if (currentScreen == SCREEN_SETUP_NETWORK) {
    if (y < 40 && x > 240) { currentScreen = SCREEN_MENU_HUB; drawMenuHub(); return; }
    if (y >= 50 && y <= 90) { openKeyboard(wifi_ssid, "WiFi SSID"); }
    else if (y >= 100 && y <= 140) { openKeyboard(wifi_pass, "WiFi Password"); }
  }
  else if (currentScreen == SCREEN_SETUP_MOTORS) {
    if (y < 40 && x > 240) { currentScreen = SCREEN_MENU_HUB; drawMenuHub(); return; }
    if (y >= 60 && y <= 95) {
      if (x < 155) openNumKeyboard(delay_m2_sec, "M2 Delay (s)");
      else openNumKeyboard(duration_m2_sec, "M2 Duration (s)");
    }
    else if (y >= 120 && y <= 155) {
      m2_auto_link = !m2_auto_link;
      saveM2Link();
      drawSetupMotors();
    }
    else if (y >= 180 && y <= 220) {
      if (x >= 50 && x <= 150) {
        digitalWrite(RELAY1_PIN, digitalRead(RELAY1_PIN) == RELAY_ON ? RELAY_OFF : RELAY_ON);
        drawSetupMotors();
      } else if (x >= 170 && x <= 270) {
        digitalWrite(RELAY2_PIN, digitalRead(RELAY2_PIN) == RELAY_ON ? RELAY_OFF : RELAY_ON);
        drawSetupMotors();
      }
    }
  }
  else if (currentScreen == SCREEN_SETUP_COLORS) {
    if (y < 40 && x > 240) { currentScreen = SCREEN_MENU_HUB; drawMenuHub(); return; }
    if (y >= 50 && y <= 90) {
      if (x < 155) { idx_col_ok = (idx_col_ok + 1) % palette_len; savePreferences(); drawSetupColors(); }
      else { idx_col_err = (idx_col_err + 1) % palette_len; savePreferences(); drawSetupColors(); }
    } else if (y >= 100 && y <= 140) {
      idx_col_act = (idx_col_act + 1) % palette_len; savePreferences(); drawSetupColors();
    }
  }
  else if (currentScreen == SCREEN_SETUP_DISPLAY) {
    if (y < 40 && x > 240) { currentScreen = SCREEN_MENU_HUB; drawMenuHub(); return; }
    if (y >= 75 && y <= 115) { openNumKeyboard(sleep_timeout, "Sleep Timeout"); }
    else if (y >= 135 && y <= 175) {
      sleep_in_minutes = !sleep_in_minutes;
      savePreferences();
      drawSetupDisplay();
    }
  }
  else if (currentScreen == SCREEN_PRINTER_SETTINGS) {
    if (y < 40 && x > 240) { currentScreen = SCREEN_MAIN; drawMainScreen(); return; }
    int p = editingPrinterIndex;
    if (y >= 40 && y <= 70) openKeyboard(printers[p].name, "Printer Name");
    else if (y >= 75 && y <= 105) openKeyboard(printers[p].ip, "Printer IP");
    else if (y >= 110 && y <= 140) openKeyboard(printers[p].accessCode, "Access Code");
    else if (y >= 145 && y <= 175) openKeyboard(printers[p].serial, "Serial Number");
    else if (y >= 180 && y <= 210) {
      if (x < 155) openNumKeyboard(printers[p].delayStartSec, "Start Delay (s)");
      else openNumKeyboard(printers[p].runTimeSec, "Run Time (s)");
    }
    else if (y >= 215 && y <= 250) {
      if (x < 105) openNumKeyboard(printers[p].poopTarget, "Poop Limit");
      else if (x >= 110 && x <= 205) { printers[p].useM1 = !printers[p].useM1; savePreferences(); drawPrinterSettings(p); }
      else if (x >= 210) { printers[p].useM2 = !printers[p].useM2; savePreferences(); drawPrinterSettings(p); }
    }
  }
}

// =================================================================================
// === 9. SETUP & LOOP ===
// =================================================================================

void setup() {
  Serial.begin(115200);

  pinMode(RELAY1_PIN, OUTPUT);
  pinMode(RELAY2_PIN, OUTPUT);
  pinMode(CYD_BACKLIGHT, OUTPUT);
  digitalWrite(RELAY1_PIN, RELAY_OFF);
  digitalWrite(RELAY2_PIN, RELAY_OFF);
  digitalWrite(CYD_BACKLIGHT, HIGH);

  // Samostatná SPI sběrnice pro dotykový čip XPT2046
  touchSpi.begin(XPT2046_CLK, XPT2046_MISO, XPT2046_MOSI, XPT2046_CS);
  ts.begin(touchSpi);
  ts.setRotation(1);

  tft.init();
  tft.setRotation(1);
  tft.fillScreen(TFT_BLACK);

  loadPreferences();
  loadCalibration();

  WiFi.mode(WIFI_STA);

  drawMainScreen();

  xTaskCreatePinnedToCore(
    networkLoop,
    "NetworkTask",
    10000,
    NULL,
    1,
    &NetworkTask,
    0
  );

  last_interaction = millis();
}

void loop() {
  checkConveyorLogic();
  checkSleep();
  updateWifiStatusUI();

  int touchX = 0, touchY = 0;
  if (isTouched(touchX, touchY)) {
    handleTouch(touchX, touchY);
    delay(150); 
  }

  if (currentScreen == SCREEN_MAIN) {
    for (int i = 0; i < 4; i++) {
      updatePrinterBox(i);
    }
  }

  delay(10);
}
