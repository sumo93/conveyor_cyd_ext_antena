  tft.drawRoundRect(x, y, w, h, 6, UI_BG); 
  tft.setTextColor(txtColor, color); 
  tft.setTextDatum(MC_DATUM); 
  tft.drawString(label, x + w/2, y + h/2, 2); 
  tft.setTextDatum(TL_DATUM); 
}

void drawBtn(int x, int y, int w, int h, const String &label, uint16_t color) { 
  drawBtn(x, y, w, h, label, color, UI_TEXT_MAIN); 
}

void drawProgressRing(int x, int y, int radius, int percent, uint16_t color) {
  tft.drawCircle(x, y, radius, RING_TRACK); 
  tft.drawCircle(x, y, radius-1, RING_TRACK); 
  tft.fillCircle(x, y, radius-2, UI_CARD_BG);

  int angle = (percent * 360) / 100;
  for (int i = 0; i < angle; i+=3) { 
      float rad = (i - 90) * 0.0174532925;
      int x1 = x + cos(rad) * radius;
      int y1 = y + sin(rad) * radius;
      int x2 = x + cos(rad) * (radius-1);
      int y2 = y + sin(rad) * (radius-1);
      tft.drawPixel(x1, y1, color);
      tft.drawPixel(x2, y2, color);
  }

  tft.setTextDatum(MC_DATUM);
  tft.setTextColor(TFT_WHITE, UI_CARD_BG); 
  tft.drawString(String(percent) + "%", x, y + 1, 1); 
}

