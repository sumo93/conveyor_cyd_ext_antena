void checkConveyorLogic() {
  if (currentScreen != SCREEN_MAIN) return; 
  unsigned long now = millis();
  
  unsigned long delay_start_ms = 2000;
  if (activePrinterIndex >= 0) {
      delay_start_ms = printers[activePrinterIndex].delayStartSec * 1000;
  }

  unsigned long delay_m2_ms = delay_m2_sec * 1000; unsigned long duration_m2_ms = duration_m2_sec * 1000; 
  
  if (conveyorState == STATE_WAITING_TO_START) { if (now - detectionTime > delay_start_ms) { runStartTime = now; conveyorState = STATE_RUNNING; if (activePrinterIndex >= 0 && printers[activePrinterIndex].useM1) digitalWrite(RELAY1_PIN, RELAY_ON); } }
  if (conveyorState == STATE_RUNNING) {
    unsigned long runningTime = now - runStartTime; bool anyRun = false;
    if (activePrinterIndex >= 0) {
       if (printers[activePrinterIndex].useM1) { if (runningTime < targetTimeM1_ms) anyRun = true; else digitalWrite(RELAY1_PIN, RELAY_OFF); } else digitalWrite(RELAY1_PIN, RELAY_OFF);
       if (printers[activePrinterIndex].useM2 && m2_auto_link) { if (runningTime > delay_m2_ms && runningTime < (delay_m2_ms + duration_m2_ms)) { digitalWrite(RELAY2_PIN, RELAY_ON); anyRun = true; } else { digitalWrite(RELAY2_PIN, RELAY_OFF); if (runningTime < delay_m2_ms) anyRun = true; } } else digitalWrite(RELAY2_PIN, RELAY_OFF);
    }
    if (!anyRun) { digitalWrite(RELAY1_PIN, RELAY_OFF); digitalWrite(RELAY2_PIN, RELAY_OFF); int finishedIndex = activePrinterIndex; conveyorState = STATE_IDLE; activePrinterIndex = -1; if(finishedIndex >= 0) { printers[finishedIndex].last_statusText = ""; updatePrinterBox(finishedIndex); } }
  }
}

void checkSleep() {
  unsigned long timeout_ms = (unsigned long)sleep_timeout * (sleep_in_minutes ? 60000 : 1000);
  if (sleep_timeout > 0 && millis() - last_interaction > timeout_ms) { if (!is_screen_off) { digitalWrite(CYD_BACKLIGHT, LOW); is_screen_off = true; } } else { if (is_screen_off) { digitalWrite(CYD_BACKLIGHT, HIGH); is_screen_off = false; } }
}

